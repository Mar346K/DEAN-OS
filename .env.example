# DEAN-OS Environment Variables Template
# Copy this file to .env and replace the values before booting the cluster.

# Security (Required)
DAEN_INTERNAL_SECRET="replace-with-a-secure-random-string"

# Database Credentials (Required)
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="your_secure_password_here"
POSTGRES_DB="deanos_ledger"

# Networking (Internal Docker Hostnames)
REDIS_HOST="redis"

# Note: API Keys (OpenAI, Anthropic, Gemini) are NOT stored here.
# They are managed via the UI and encrypted into the Zero-Knowledge Vault by Valkyrie.
